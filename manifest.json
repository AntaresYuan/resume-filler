{
  "manifest_version": 3,
  "name": "ApplyMint",
  "version": "2.2",
  "description": "把简历整理成 JSON，一次导入后可视化编辑，并在求职表单上一键自动填写",
  "permissions": ["activeTab", "storage", "scripting", "sidePanel"],
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["schema.js", "lib/field-detect.js", "content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
